<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Firebase Analytics auto-injects the advertising-ID permission. Macaco does no ads and our
         Play "advertising ID" declaration says we don't use it, so strip it to keep them in sync
         (Play rejects the upload otherwise). -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <!-- Travel reminder notifications (runtime-requested on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Needed only on API <= 28 to write entry photos into the shared Pictures collection
         (so they survive an uninstall). On API 29+ MediaStore writes need no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- Re-read entry videos in Movies/Macaco after a reinstall on API 33+
         (recording itself happens in the system camera app, which holds its own
         RECORD_AUDIO grant — we don't need one). -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Required (API 29+) to read unredacted GPS EXIF from camera-roll photos this app didn't
         create — load-bearing for the auto-suggested-entries feature (util/PhotoRollScanner.kt):
         without it MediaStore hands back location-redacted copies and no cluster is ever found.
         Runtime-requested together with the media-read permission, only when the feature runs. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <!-- Resolve the system video-capture intent (API 30+ package-visibility rules). -->
    <queries>
        <intent>
            <action android:name="android.media.action.VIDEO_CAPTURE" />
        </intent>
    </queries>

    <!-- androidx.biometric pulls in USE_FINGERPRINT which implies this feature is required;
         override to "false" so devices without a fingerprint sensor aren't filtered out. -->
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />

    <application
        android:name=".TravelJournalApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Macaco.Splash"
        android:localeConfig="@xml/locales_config">
        <activity
            android:name=".MainActivity"
            android:configChanges="locale|layoutDirection|orientation|screenSize|screenLayout"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Macaco.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- "Remind me later" action on the journal-reminder notification. -->
        <receiver
            android:name=".util.SnoozeReceiver"
            android:exported="false" />

        <!-- "On This Day" home-screen widget. -->
        <receiver
            android:name=".ui.widget.OnThisDayWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/on_this_day_widget_info" />
        </receiver>

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Persists the in-app language choice across restarts on API < 33
             (on API 33+ the system stores it). -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>
