    <!-- Help &amp; About -->
    <string name="help_title">帮助与关于</string>
    <string name="help_faq">常见问题</string>
    <string name="help_faq_q_sync">我的记录保存在哪里？</string>
    <string name="help_faq_a_sync">您的记录会安全地同步到云端账户，因此在您登录的任何设备上都能查看。</string>
    <string name="help_faq_q_photos">为什么我的照片在其他设备上看不到？</string>
    <string name="help_faq_a_photos">照片保存在添加它们的设备上。请在“设置”中连接 Google Drive，或使用“备份到文件”，以便在设备间携带照片。</string>
    <string name="help_faq_q_backup">如何备份所有内容？</string>
    <string name="help_faq_a_backup">在“设置 → 备份与恢复”中，您可以将所有记录和照片导出为单个 .zip 文件，并随时重新导入。</string>
    <string name="help_faq_q_lock">可以锁定应用吗？</string>
    <string name="help_faq_a_lock">可以 — 在菜单或“设置”中开启应用锁，打开 Macaco 时即需指纹、面容或屏幕锁验证。</string>
    <string name="help_faq_q_billing">如何取消或申请退款？</string>
    <string name="help_faq_a_billing">订阅和购买由 Google Play 计费。打开“订阅”可管理您的方案，或前往 Play 商店 → 付款和订阅进行取消。如需退款，请在 48 小时内通过 Play 商店的订单记录办理，或联系我们。</string>
