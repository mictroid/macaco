<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- windowBackground is the brand teal (matching the splash) so the brief window shown while the
         activity is recreated — e.g. after a language change calls setApplicationLocales() — is branded
         instead of the DayNight colorBackground (near-black in dark mode). -->
    <style name="Theme.MyApplication" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <!-- Launch theme: shows the teal brand colour + monkey while the process starts, then
         hands off to the app theme. Prevents a blank/white cold-start flash. -->
    <style name="Theme.Macaco.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
        <!-- Cover the gap between activity (re)creation and the first Compose frame with the branded
             teal + centered monkey (not a blank teal rectangle), so the long cold-start window on
             slow devices reads as the splash rather than a blank blue screen. Also kills the
             first-language-switch flash (teal, not the inherited black windowBackground). -->
        <item name="android:windowBackground">@drawable/splash_window_bg</item>
    </style>
</resources>