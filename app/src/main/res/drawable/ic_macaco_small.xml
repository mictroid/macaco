<?xml version="1.0" encoding="utf-8"?>
<!--
  Small-scale Macaco monkey icon — head circle + sunglasses only.
  Ears, inner ears, muzzle, eyebrows and nostrils are omitted; they
  become unreadable below ~64dp and muddy the silhouette. Stroke widths
  are increased (~40% heavier than the full ic_launcher_foreground) to
  compensate for the reduced render size. Same 1024×1024 viewport and
  0.9-scale group as the full icon so proportions are identical.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <group
        android:pivotX="512"
        android:pivotY="512"
        android:scaleX="0.9"
        android:scaleY="0.9">

        <!-- Head outline -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="35"
            android:pathData="M270,504 a242,242 0 1,0 484,0 a242,242 0 1,0 -484,0" />

        <!-- Left sunglass lens -->
        <path
            android:fillColor="#040E14"
            android:strokeColor="#E8B020"
            android:strokeWidth="28"
            android:pathData="M335,484 a83,83 0 1,0 166,0 a83,83 0 1,0 -166,0" />

        <!-- Right sunglass lens -->
        <path
            android:fillColor="#040E14"
            android:strokeColor="#E8B020"
            android:strokeWidth="28"
            android:pathData="M523,484 a83,83 0 1,0 166,0 a83,83 0 1,0 -166,0" />

        <!-- Nose bridge — connects lenses so they read as sunglasses, not two dots -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="20"
            android:strokeLineCap="round"
            android:pathData="M501,484 L524,484" />

    </group>
</vector>
