<?xml version="1.0" encoding="utf-8"?>
<!--
  Macaco launcher foreground: a sunglasses-wearing monkey rendered as gold line-art.
  Ported from macaco_monkey_icon.svg (1024x1024 artwork space). The SVG glow filter and
  gradient strokes are dropped (unsupported by VectorDrawable); strokes use solid brand gold.
  The outer group scales the art to 0.9 about the centre so the ears stay inside the
  adaptive-icon safe zone (no mask clipping).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <group
        android:pivotX="512"
        android:pivotY="512"
        android:scaleX="0.9"
        android:scaleY="0.9">

        <!-- Muzzle (behind glasses) -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="23"
            android:pathData="M420,613 a92,63 0 1,0 184,0 a92,63 0 1,0 -184,0" />

        <!-- Head -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="25"
            android:pathData="M270,504 a242,242 0 1,0 484,0 a242,242 0 1,0 -484,0" />

        <!-- Ears -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="23"
            android:pathData="M186,487 a94,94 0 1,0 188,0 a94,94 0 1,0 -188,0" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="23"
            android:pathData="M650,487 a94,94 0 1,0 188,0 a94,94 0 1,0 -188,0" />

        <!-- Inner ear bowls -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="15"
            android:pathData="M224,487 a56,59 0 1,0 112,0 a56,59 0 1,0 -112,0" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="15"
            android:pathData="M688,487 a56,59 0 1,0 112,0 a56,59 0 1,0 -112,0" />

        <!-- Sunglasses — dark filled lenses -->
        <path
            android:fillColor="#040E14"
            android:strokeColor="#E8B020"
            android:strokeWidth="21"
            android:pathData="M335,484 a83,83 0 1,0 166,0 a83,83 0 1,0 -166,0" />
        <path
            android:fillColor="#040E14"
            android:strokeColor="#E8B020"
            android:strokeWidth="21"
            android:pathData="M523,484 a83,83 0 1,0 166,0 a83,83 0 1,0 -166,0" />

        <!-- Nose bridge -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:pathData="M501,484 L524,484" />

        <!-- Temple arms -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:pathData="M335,484 L283,487" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="15"
            android:strokeLineCap="round"
            android:pathData="M689,484 L741,487" />

        <!-- Eyebrows -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="18"
            android:strokeLineCap="round"
            android:pathData="M369,395 Q418,372 466,395" />
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E8B020"
            android:strokeWidth="18"
            android:strokeLineCap="round"
            android:pathData="M558,395 Q606,372 655,395" />

        <!-- Nostrils -->
        <path
            android:fillColor="#E8B020"
            android:pathData="M475,629 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0" />
        <path
            android:fillColor="#E8B020"
            android:pathData="M523,629 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0" />
    </group>
</vector>
