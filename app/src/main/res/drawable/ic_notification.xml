<!-- Monochrome status-bar icon. Android tints the small icon by its alpha only, so this is
     white paths on transparent: head + ears outlines with the two filled lenses (the signature
     detail). Stays legible at 18-24dp where the full-colour ic_macaco_small collapses. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Head circle -->
    <path
        android:pathData="M50,50 m-32,0 a32,32 0 1,0 64,0 a32,32 0 1,0 -64,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:fillColor="@android:color/transparent" />

    <!-- Left ear -->
    <path
        android:pathData="M18,42 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:fillColor="@android:color/transparent" />

    <!-- Right ear -->
    <path
        android:pathData="M82,42 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:fillColor="@android:color/transparent" />

    <!-- Left lens (filled) -->
    <path
        android:pathData="M38,48 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"
        android:fillColor="#FFFFFF" />

    <!-- Right lens (filled) -->
    <path
        android:pathData="M62,48 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"
        android:fillColor="#FFFFFF" />

</vector>
