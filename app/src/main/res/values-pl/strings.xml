    <!-- Help &amp; About -->
    <string name="help_title">Pomoc i informacje</string>
    <string name="help_faq">Najczęstsze pytania</string>
    <string name="help_faq_q_sync">Gdzie są przechowywane moje wpisy?</string>
    <string name="help_faq_a_sync">Twoje wpisy są bezpiecznie synchronizowane z Twoim kontem w chmurze, więc towarzyszą Ci na każdym urządzeniu, na którym się zalogujesz.</string>
    <string name="help_faq_q_photos">Dlaczego moje zdjęcia nie pojawiają się na innym urządzeniu?</string>
    <string name="help_faq_a_photos">Zdjęcia są zapisywane na urządzeniu, z którego je dodano. Połącz Google Drive w Ustawieniach lub użyj „Kopia do pliku”, aby przenosić zdjęcia między urządzeniami.</string>
    <string name="help_faq_q_backup">Jak utworzyć kopię wszystkiego?</string>
    <string name="help_faq_a_backup">Ustawienia → Kopia i przywracanie pozwala wyeksportować wszystkie wpisy i zdjęcia do jednego pliku .zip, który możesz w każdej chwili ponownie zaimportować. Zarówno ta funkcja, jak i automatyczna kopia zapasowa zdjęć w Google Drive to funkcje Premium.</string>
    <string name="help_faq_q_lock">Czy mogę zablokować aplikację?</string>
    <string name="help_faq_a_lock">Tak – włącz Blokadę aplikacji z menu lub Ustawień, aby otwarcie Macaco wymagało odcisku palca, twarzy lub blokady ekranu.</string>
    <string name="help_faq_q_billing">Jak anulować lub uzyskać zwrot?</string>
    <string name="help_faq_a_billing">Subskrypcje i zakupy rozlicza Google Play. Otwórz Subskrypcję, aby zarządzać planem, lub przejdź do Sklepu Play → Płatności i subskrypcje, aby anulować. Po zwrot zgłoś się w ciągu 48 godzin przez historię zamówień w Sklepie Play lub skontaktuj się z nami.</string>
    <string name="help_request_feature">Zaproponuj funkcję</string>
    <string name="help_report_issue">Zgłoś problem</string>
    <string name="help_section_getting_started">Pierwsze kroki</string>
    <string name="help_section_photos">Zdjęcia</string>
    <string name="help_section_sync">Synchronizacja i urządzenia</string>
    <string name="help_section_privacy">Prywatność i bezpieczeństwo</string>
    <string name="help_section_premium">Premium</string>
    <string name="help_faq_create_entry_q">Jak utworzyć wpis?</string>
    <string name="help_faq_create_entry_a">Naciśnij przycisk + na ekranie dziennika. Dodaj tytuł, lokalizację, datę, zdjęcia, nastrój i tagi — albo tylko tytuł i kilka słów. Wszystko zapisuje się automatycznie.</string>
    <string name="help_faq_swipe_entries_q">Jak przełączać się między wpisami?</string>
    <string name="help_faq_swipe_entries_a">Na liście dziennika przesuń palcem w lewo lub w prawo na karcie wpisu, aby przejść do następnego lub poprzedniego wspomnienia. Licznik u góry pokazuje twoją pozycję.</string>
    <string name="help_faq_adventures_map_q">Czym jest mapa Przygody?</string>
    <string name="help_faq_adventures_map_a">Mapa Przygody pokazuje na mapie świata każde miejsce zapisane w dzienniku. Naciśnij ikonę globusa na ekranie dziennika, aby ją otworzyć. Pinezki są grupowane według miast — naciśnij grupę, aby przybliżyć.</string>
    <string name="help_faq_reel_q">Czym jest Adventure Reel?</string>
    <string name="help_faq_reel_a">Adventure Reel zamienia wszystkie zdjęcia z podróży w krótki, filmowy klip — idealny do udostępniania lub zachowania na pamiątkę. Dotknij przycisku 🎬 w nagłówku dowolnej podróży na liście wpisów, aby go utworzyć. Macaco zajmie się resztą: animacja Kena Burnsa, płynne przejścia oraz Twoja lokalizacja i data na każdym zdjęciu. Adventure Reel to funkcja premium.</string>
    <string name="help_faq_free_trial_q">Czy jest dostępny bezpłatny okres próbny?</string>
    <string name="help_faq_free_trial_a">Tak — plan roczny obejmuje 7-dniowy bezpłatny okres próbny. Opłata zostanie pobrana dopiero po zakończeniu okresu próbnego, a w jego trakcie możesz anulować w dowolnym momencie bez obciążenia. Plany miesięczny i dożywotni nie obejmują okresu próbnego.</string>
    <string name="help_faq_map_pins_q">Dlaczego na mapie Przygód brakuje niektórych pinezek?</string>
    <string name="help_faq_map_pins_a">Gdy Twoje przygody obejmują ponad mniej więcej połowę globu — na przykład wpisy w Japonii i Argentynie — mapa nie może pokazać wszystkich pinezek naraz przy czytelnym poziomie powiększenia. Dotknij strzałek ◀ lub ▶ na krawędziach mapy, aby przejść do pinezek poza ekranem. Nagłówek pokazuje, ile lokalizacji zostało naniesionych, więc wiesz, czy jakichś brakuje.</string>
    <string name="help_faq_reset_password_q">Jak zresetować hasło?</string>
    <string name="help_faq_reset_password_a">Na ekranie logowania dotknij \"Nie pamiętasz hasła?\" i wpisz swój adres e-mail. W ciągu kilku sekund otrzymasz link do resetowania. Dotyczy to tylko kont z adresem e-mail i hasłem — jeśli logujesz się przez Google, zarządzaj hasłem na swoim koncie Google.</string>
    <string name="help_faq_reorder_photos_q">Jak zmienić kolejność lub usunąć zdjęcia?</string>
    <string name="help_faq_reorder_photos_a">Otwórz wpis i przytrzymaj dowolne zdjęcie na pasku miniatur. Pojawi się menu z opcjami przeniesienia zdjęcia w lewo lub w prawo, usunięcia go z wpisu lub ustawienia jako zdjęcie okładki. Zdjęcie pozostaje w Twojej galerii po usunięciu z wpisu.</string>
    <string name="help_faq_cover_q">Jak zmienić zdjęcie okładki wpisu?</string>
    <string name="help_faq_cover_a">Otwórz wpis, przytrzymaj dowolne zdjęcie na pasku miniatur, a następnie dotknij \"Ustaw jako okładkę\". Wybrane zdjęcie stanie się głównym zdjęciem na górze wpisu i miniaturą wyświetlaną na liście wpisów.</string>
    <string name="help_faq_use_tags_q">Jak używać tagów?</string>
    <string name="help_faq_use_tags_a">Wpisz tag w edytorze wpisu i naciśnij przycisk +, aby go dodać. Tagi pozwalają grupować wpisy według podróży, motywu lub dowolnej etykiety. Dotknij chipa tagu przy dowolnym wpisie na liście dziennika, aby filtrować według tego tagu.</string>
    <string name="help_faq_transfer_device_q">Przeniesienie na nowe urządzenie</string>
    <string name="help_faq_transfer_device_a">Zaloguj się na nowym urządzeniu tym samym kontem Google lub e-mail. Twoje wpisy synchronizują się automatycznie w kilka sekund. Zdjęcia zapisane przez Kopię zapasową i przywracanie również zostaną przywrócone po ponownym zaimportowaniu pliku kopii.</string>
    <string name="help_faq_premium_benefits_q">Co daje premium?</string>
    <string name="help_faq_premium_benefits_a">Premium odblokowuje nieograniczone wpisy, pokazy wideo Adventure Reel, drukowane fotoksiążki, kopię zapasową zdjęć w Google Drive oraz pełną kopię zapasową/przywracanie do pliku. Mapa Przygód, przesuwanie między wpisami i własne motywy są bezpłatne dla wszystkich. Dostępne jako plan miesięczny, roczny (z 7-dniowym bezpłatnym okresem próbnym) lub dożywotni.</string>
    <string name="help_faq_premium_broken_q">Premium nie działa?</string>
    <string name="help_faq_premium_broken_a">Spróbuj przywrócić zakup: dotknij ikony profilu, następnie dotknij Subskrypcja i dotknij Przywróć zakup. Upewnij się, że jesteś zalogowany na tym samym koncie, którego użyto przy zakupie. Jeśli nadal nie działa, napisz do nas na houseofmmminq@gmail.com.</string>
    <string name="help_section_account">Konto</string>
    <string name="help_faq_delete_account_q">Jak usunąć moje konto?</string>
    <string name="help_faq_delete_account_a">Otwórz profil i dotknij Usuń konto na dole. Spowoduje to trwałe usunięcie wszystkich wpisów z chmury oraz usunięcie konta — nie można tego cofnąć. Twoje zdjęcia pozostaną w galerii urządzenia. Jeśli chcesz się tylko wylogować, użyj zamiast tego Wyloguj.</string>
    <string name="help_faq_on_this_day_q">Czym jest \"Tego dnia\"?</string>
    <string name="help_faq_on_this_day_a">Gdy masz wpisy z tej samej daty w poprzednim roku, Macaco wyświetla baner \"Tego dnia\" na górze dziennika. Dotknij go, aby wrócić do tych wspomnień. Baner pojawia się tylko w odpowiadającym dniu kalendarzowym każdego roku.</string>
    <string name="help_faq_drive_connect_q">Jak połączyć Google Drive do kopii zapasowej zdjęć?</string>
    <string name="help_faq_drive_connect_a">Przejdź do Ustawienia → Synchronizacja Drive i dotknij Połącz Google Drive. Zaloguj się kontem Google — może to być to samo konto, którego używasz do logowania, lub inne. Po połączeniu Macaco automatycznie tworzy kopię zapasową zdjęć z wpisów w folderze \"Macaco\" na Twoim Drive i przywraca je na każdym urządzeniu, na którym się zalogujesz.</string>
    <string name="help_faq_trips_q">Czym są podróże?</string>
    <string name="help_faq_trips_a">Podróż to etykieta grupująca powiązane wpisy w dzienniku. Podczas tworzenia lub edycji wpisu wpisz nazwę podróży w polu Podróż — wszystkie wpisy o tej samej nazwie są grupowane pod jednym nagłówkiem na liście wpisów. Podróże są opcjonalne; wpisy bez podróży pojawiają się bez grupowania.</string>
