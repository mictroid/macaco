    <!-- Help &amp; About -->
    <string name="help_title">Pomoc i informacje</string>
    <string name="help_faq">Najczęstsze pytania</string>
    <string name="help_faq_q_sync">Gdzie są przechowywane moje wpisy?</string>
    <string name="help_faq_a_sync">Twoje wpisy są bezpiecznie synchronizowane z Twoim kontem w chmurze, więc towarzyszą Ci na każdym urządzeniu, na którym się zalogujesz.</string>
    <string name="help_faq_q_photos">Dlaczego moje zdjęcia nie pojawiają się na innym urządzeniu?</string>
    <string name="help_faq_a_photos">Zdjęcia są zapisywane na urządzeniu, z którego je dodano. Połącz Google Drive w Ustawieniach lub użyj „Kopia do pliku”, aby przenosić zdjęcia między urządzeniami.</string>
    <string name="help_faq_q_backup">Jak utworzyć kopię wszystkiego?</string>
    <string name="help_faq_a_backup">Ustawienia → Kopia i przywracanie pozwala wyeksportować wszystkie wpisy i zdjęcia do jednego pliku .zip, który możesz w każdej chwili ponownie zaimportować.</string>
    <string name="help_faq_q_lock">Czy mogę zablokować aplikację?</string>
    <string name="help_faq_a_lock">Tak – włącz Blokadę aplikacji z menu lub Ustawień, aby otwarcie Macaco wymagało odcisku palca, twarzy lub blokady ekranu.</string>
    <string name="help_faq_q_billing">Jak anulować lub uzyskać zwrot?</string>
    <string name="help_faq_a_billing">Subskrypcje i zakupy rozlicza Google Play. Otwórz Subskrypcję, aby zarządzać planem, lub przejdź do Sklepu Play → Płatności i subskrypcje, aby anulować. Po zwrot zgłoś się w ciągu 48 godzin przez historię zamówień w Sklepie Play lub skontaktuj się z nami.</string>
    <string name="help_request_feature">Zaproponuj funkcję</string>
    <string name="help_report_issue">Zgłoś problem</string>
    <string name="help_section_getting_started">Pierwsze kroki</string>
    <string name="help_section_photos">Zdjęcia</string>
    <string name="help_section_sync">Synchronizacja i urządzenia</string>
    <string name="help_section_privacy">Prywatność i bezpieczeństwo</string>
    <string name="help_section_premium">Premium</string>
    <string name="help_faq_create_entry_q">Jak utworzyć wpis?</string>
    <string name="help_faq_create_entry_a">Naciśnij przycisk + na ekranie dziennika. Dodaj tytuł, lokalizację, datę, zdjęcia, nastrój i tagi — albo tylko tytuł i kilka słów. Wszystko zapisuje się automatycznie.</string>
    <string name="help_faq_swipe_entries_q">Jak przełączać się między wpisami?</string>
    <string name="help_faq_swipe_entries_a">Na liście dziennika przesuń palcem w lewo lub w prawo na karcie wpisu, aby przejść do następnego lub poprzedniego wspomnienia. Licznik u góry pokazuje twoją pozycję.</string>
    <string name="help_faq_adventures_map_q">Czym jest mapa Przygody?</string>
    <string name="help_faq_adventures_map_a">Mapa Przygody pokazuje na mapie świata każde miejsce zapisane w dzienniku. Naciśnij ikonę globusa na ekranie dziennika, aby ją otworzyć. Pinezki są grupowane według miast — naciśnij grupę, aby przybliżyć.</string>
    <string name="help_faq_transfer_device_q">Przeniesienie na nowe urządzenie</string>
    <string name="help_faq_transfer_device_a">Zaloguj się na nowym urządzeniu tym samym kontem Google lub e-mail. Twoje wpisy synchronizują się automatycznie w kilka sekund. Zdjęcia zapisane przez Kopię zapasową i przywracanie również zostaną przywrócone po ponownym zaimportowaniu pliku kopii.</string>
    <string name="help_faq_premium_benefits_q">Co daje premium?</string>
    <string name="help_faq_premium_benefits_a">Premium odblokowuje pełne możliwości Macaco: nieograniczone wpisy w dzienniku, mapę Przygody, przewijanie między wpisami, własne motywy i priorytetowe wsparcie. Dostępne w planie miesięcznym, rocznym lub dożywotnim.</string>
    <string name="help_faq_premium_broken_q">Premium nie działa?</string>
    <string name="help_faq_premium_broken_a">Spróbuj przywrócić zakup: przejdź do Ustawienia → Premium i naciśnij Przywróć zakupy. Upewnij się, że logujesz się tym samym kontem, którego użyto przy zakupie. Jeśli nadal nie działa, napisz do nas na houseofmmminq@gmail.com.</string>
    <string name="help_faq_cancel_plan_q">Zmień lub anuluj plan</string>
